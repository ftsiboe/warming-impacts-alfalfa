# ── R / RStudio ────────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Renviron
.Rproj.user
# knitr / rmarkdown scratch
*_cache/
*_files/
*.utf8.md
*.knit.md

# ── OS / editor cruft ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~
.vscode/
.idea/

# ── Data (large; distributed via GitHub Releases / piggyback, not committed) ─
# Processed inputs and the raw PRISM panels are large .rds files. Fetch them
# from the "data" release rather than tracking them in git.
data/*.rds
data/**/*.rds
data/prism_climate/
data/prism_weather/
data/fastscratch/

# ── Fast-scratch working area (all pipeline intermediates; never committed) ─
# study_environment$wd$* resolve to fastscratch/<name>; safe to delete anytime.
fastscratch/

# ── Generated outputs (rebuilt by the pipeline; released via piggyback) ─────
# 000_initialize recreates this tree; the packaged archive lives in the
# "outputs" release. Nothing under output/ is version-controlled.
output/

# ── Article build artifacts ────────────────────────────────────────────────
# article_objects.json is generated by 301; the rendered article by 302.
narrative/article_objects.json
narrative/article_warming_effects_alfalfa.docx
narrative/article_warming_effects_alfalfa.html
# LaTeX / knitr aux from rendering
narrative/*.log
narrative/*.aux
narrative/*.out
narrative/*.synctex.gz
narrative/*.toc

# NOTE: kept ON PURPOSE — narrative/reference.docx (style ref),
# narrative/references.bib, and everything under narrative/sections/.
